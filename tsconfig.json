{
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "./out-tsc",
    "sourceMap": true,
    "declaration": false,
    "esModuleInterop": true,
    "module": "es2020",
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "ES2022",
    "typeRoots": [
      "node_modules/@types"
    ],
    "baseUrl": "./",
    "paths": {
      "@app/*": [
        "src/app/*"
      ],
      "@services/*": [
        "src/app/services/*"
      ],
      "@modules/*": [
        "src/app/modules/*"
      ],
      "@models/*": [
        "src/app/models/*"
      ],
      "@components/*": [
        "src/app/components/*"
      ]
    }
  },
  "exclude": [
    "**/*.spec.ts"
  ]
}

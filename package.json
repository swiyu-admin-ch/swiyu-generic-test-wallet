{
  "name": "test-wallet-frontend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.json",
    "build": "ng build --configuration production",
    "test": "ng test --no-watch",
    "test:watch": "ng test",
    "test:coverage": "ng test --coverage",
    "lint": "ng lint",
    "generate:apis": "npm run generate:issuer-api && npm run generate:verifier-api",
    "generate:issuer-api": "openapi-generator-cli generate -i openapi-spec/issuer-api.yaml -g typescript-angular -o src/generated/issuer --additional-properties=providedInRoot=true --skip-validate-spec",
    "generate:verifier-api": "openapi-generator-cli generate -i openapi-spec/verifier-api.yaml -g typescript-angular -o src/generated/verifier --additional-properties=providedInRoot=true --skip-validate-spec",
    "clean:generated": "rm -rf src/generated"
  },
  "dependencies": {
    "@angular/animations": "^21.2.6",
    "@angular/cdk": "^21.2.0",
    "@angular/common": "^21.2.4",
    "@angular/compiler": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@mui/icons-material": "^7.3.4",
    "@sd-jwt/present": "^0.19.0",
    "@sd-jwt/utils": "^0.19.0",
    "jose": "^6.2.1",
    "rxjs": "^7.8.0",
    "service": "^0.1.4",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/core": "^21.2.5",
    "@openapitools/openapi-generator-cli": "^2.30.0",
    "@types/node": "^25.5.0",
    "@vitest/browser": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "angular-eslint": "21.2.0",
    "eslint": "^9.39.1",
    "jsdom": "^29.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.46.4",
    "vitest": "^4.1.0"
  }
}
